---
const SKILLS = [
  {
    category: "Soft Skills",
    items: ["Hands on", "Open minded", "Perfil emprendedor", "Pensamiento crítico"]
  },
  {
    category: "Herramientas",
    items: ["Paquete Office"]
  },
  {
    category: "Programación",
    items: ["C++", "Python", "SQL"]
  }
]
---

<div class="flex flex-col gap-y-8 mt-16">
  {
    SKILLS.map(({ category, items }) => (
      <div>
        <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 mb-4">{category}</h3>
        <ul class="flex flex-wrap gap-4">
          {items.map((item) => (
            <li class="bg-gray-200 text-gray-800 dark:bg-gray-800 dark:text-gray-300 text-sm font-medium px-4 py-2 rounded-full border border-gray-300 dark:border-gray-700">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
